---
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('testimonials', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  entries.map(async (t) => ({ entry: t, Content: (await render(t)).Content }))
);

const perPage = 3;
const pages = [];
for (let i = 0; i < rendered.length; i += perPage) {
  pages.push(rendered.slice(i, i + perPage));
}
---
<section id="testimonials" class="relative py-24 md:py-32 overflow-hidden" style="background-color:var(--bg-elevated)">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="testi_tag">Cerita tentang pulang</p>
            <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight mb-6" style="color:var(--text-primary)"><span data-i18n="testi_title_1">Kata-kata dari mereka yang</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="testi_title_2">menemukan jalan pulang</span></h2>
        </div>
        <div class="relative">
            <div class="overflow-hidden rounded-2xl">
                <div id="testimonialTrack" class="testimonial-track flex">
                    {pages.map((page) => (
                        <div class="w-full flex-shrink-0 px-4">
                            <div class="grid md:grid-cols-3 gap-6">
                                {page.map(({ entry, Content }) => (
                                    <div class="p-6 rounded-2xl border th-card" style="background:var(--bg-card);border-color:var(--border-main)">
                                        <div class="flex gap-1 mb-3">
                                            {[...Array(5)].map(() => <i data-lucide="star" class="w-3.5 h-3.5 fill-current" style="color:var(--star-color)"></i>)}
                                        </div>
                                        <div class="leading-relaxed mb-5 italic font-serif text-sm" style="color:var(--text-secondary)"><Content /></div>
                                        <div class="flex items-center gap-3">
                                            <div class={`w-9 h-9 rounded-full bg-gradient-to-br from-${entry.data.avatarFrom} to-${entry.data.avatarTo} flex items-center justify-center text-xs font-semibold text-white`}>{entry.data.initial}</div>
                                            <div><p class="text-sm font-medium" style="color:var(--text-primary)">{entry.data.name}</p><p class="text-xs" style="color:var(--text-muted)">{entry.data.batch}</p></div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
            <div class="flex items-center justify-center gap-4 mt-8">
                <button id="prevTestimonial" class="w-10 h-10 rounded-full border flex items-center justify-center" style="border-color:var(--border-main);color:var(--text-muted)"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
                <div id="testimonialDots" class="flex gap-2">
                    {pages.map((_, i) => <div class="dot w-2 h-2 rounded-full" style={`background:${i === 0 ? 'var(--accent)' : 'var(--text-faint)'}`}></div>)}
                </div>
                <button id="nextTestimonial" class="w-10 h-10 rounded-full border flex items-center justify-center" style="border-color:var(--border-main);color:var(--text-muted)"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let cs = 0;
        const tr = document.getElementById('testimonialTrack');
        const dots = Array.from(document.querySelectorAll('#testimonialDots .dot'));
        const ts = dots.length;
        if (!tr || ts <= 1) return;
        function uc() {
            tr!.style.transform = `translateX(-${cs * 100}%)`;
            dots.forEach((dot, i) => {
                (dot as HTMLElement).style.background = i === cs ? 'var(--accent)' : 'var(--text-faint)';
            });
        }
        document.getElementById('prevTestimonial')?.addEventListener('click', () => { cs = (cs - 1 + ts) % ts; uc(); });
        document.getElementById('nextTestimonial')?.addEventListener('click', () => { cs = (cs + 1) % ts; uc(); });
        setInterval(() => { cs = (cs + 1) % ts; uc(); }, 8000);
    });
</script>
