---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props;
const { title, tagline, description, icon, features } = product.data;
---
<div class="th-card rounded-2xl border p-6 flex flex-col" style="background:var(--bg-card);border-color:var(--border-main)">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:var(--accent-soft)"><i data-lucide={icon} class="w-6 h-6" style="color:var(--accent)"></i></div>
    <h3 class="font-serif text-xl font-semibold mb-1" style="color:var(--text-primary)">{title}</h3>
    <p class="text-sm italic font-serif mb-4" style="color:var(--accent-text)">{tagline}</p>
    <p class="text-sm leading-relaxed mb-5" style="color:var(--text-secondary)">{description}</p>
    <ul class="space-y-2 mb-6 flex-1">
        {features.map((f) => (
            <li class="flex items-start gap-2"><i data-lucide={f.icon} class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" style="color:var(--accent)"></i><span class="text-xs" style="color:var(--text-secondary)">{f.text}</span></li>
        ))}
    </ul>
    <a href={`/products/${product.id}/`} class="px-5 py-2.5 rounded-full text-sm font-medium text-center flex items-center justify-center gap-2" style="background:var(--accent);color:#fff">
        <span>Lihat Detail</span><i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
    </a>
</div>
