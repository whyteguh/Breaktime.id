---
import Base from '../layouts/Base.astro';
---
<Base title="404 — breaktime.id" description="Halaman tidak ditemukan.">
    <section class="relative min-h-[70vh] flex items-center justify-center text-center px-6 pt-24">
        <div>
            <p class="font-serif text-6xl md:text-8xl font-semibold mb-4" style="color:var(--accent)">404</p>
            <p class="text-lg mb-8" style="color:var(--text-secondary)">Halaman ini sedang beristirahat di tempat lain.</p>
            <a href="/" class="th-btn-primary px-6 py-3 rounded-full text-sm font-medium inline-flex items-center gap-2">← kembali ke beranda</a>
        </div>
    </section>
</Base>
