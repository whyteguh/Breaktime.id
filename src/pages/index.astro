---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import EventFeature from '../components/EventFeature.astro';
import BlogCard from '../components/BlogCard.astro';
import GiftCard from '../components/GiftCard.astro';
import Testimonials from '../components/Testimonials.astro';
import Newsletter from '../components/Newsletter.astro';

const products = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const events = (await getCollection('events', ({ data }) => !data.draft))
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());
const now = Date.now();
const nextEvent = events.find((e) => e.data.startDate.getTime() >= now) ?? events[events.length - 1];

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const gifts = (await getCollection('gift', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title="breaktime.id — A Journey on Finding Magic">

    <!-- ===== HERO ===== -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
            <div class="breathe absolute w-[600px] h-[600px] md:w-[800px] md:h-[800px] rounded-full" style="background:var(--hero-circle-1);border:1px solid var(--hero-circle-border)"></div>
            <div class="breathe-delay absolute w-[400px] h-[400px] md:w-[550px] md:h-[550px] rounded-full" style="background:var(--hero-circle-2);border:1px solid var(--hero-circle-border)"></div>
            <div class="breathe absolute w-[200px] h-[200px] md:w-[300px] md:h-[300px] rounded-full" style="background:var(--hero-circle-3);border:1px solid var(--hero-circle-border)"></div>
        </div>
        <div class="absolute inset-0 nature-pattern opacity-50"></div>
        <div class="relative z-10 text-center max-w-4xl mx-auto px-6 py-32">
            <div class="fade-in-up"><p class="text-xs font-bold tracking-[0.3em] uppercase mb-6" style="color:var(--accent)">breaktime.id</p></div>
            <h1 class="fade-in-up-delay font-serif text-5xl md:text-7xl lg:text-8xl font-semibold leading-[1.1] tracking-tight mb-6" style="color:var(--text-primary)">A Journey on<br><span class="italic" style="color:var(--accent)">Finding Magic</span></h1>
            <p class="fade-in-up-delay2 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed" style="color:var(--text-secondary)" data-i18n="hero_desc">Ketika dunia memintamu terus melangkah, kami mengundangmu untuk berhenti sejenak. Breaktime adalah ruang lembut untuk menemukan jalan pulang — dari malam tergelap menuju cahaya yang sunyi.</p>
            <div class="fade-in-up-delay2 flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/products/" class="group th-btn-primary px-8 py-3.5 rounded-full text-sm font-medium flex items-center gap-2"><span data-i18n="hero_cta1">Jelajahi Produk</span><i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i></a>
                <a href="#about" class="th-btn-outline px-8 py-3.5 rounded-full text-sm font-medium border" data-i18n="hero_cta2">Pelajari Lebih Lanjut</a>
            </div>
        </div>
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 float-gentle"><div class="flex flex-col items-center gap-2" style="color:var(--text-faint)"><span class="text-xs tracking-widest uppercase" data-i18n="hero_scroll">Gulir perlahan</span><i data-lucide="chevron-down" class="w-4 h-4"></i></div></div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section id="about" class="relative py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div>
                    <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="about_tag">Tentang breaktime</p>
                    <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight mb-8" style="color:var(--text-primary)"><span data-i18n="about_title_1">Bukan patah.</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="about_title_2">Terobosan.</span></h2>
                    <div class="space-y-6 leading-relaxed" style="color:var(--text-secondary)">
                        <p data-i18n="about_p1">Kami percaya bahwa momen-momen tergelap bukan tanda kelemahan — melainkan undangan. Undangan untuk berhenti, merasakan, dan perlahan menemukan jalan kembali ke diri sendiri.</p>
                        <p data-i18n="about_p2">Breaktime.id lahir dari kebenaran sederhana: istirahat bukanlah hadiah atas produktivitas. Ia adalah tanah dari mana segalanya tumbuh. Kami menenun psikologi, filsafat, neurosains, dan kebijaksanaan kuno — bukan sebagai alat optimasi, melainkan sebagai sahabat bagi jiwa.</p>
                        <p data-i18n="about_p3">Kami tidak memperbaiki orang. Kami berjalan di samping mereka. Dan ketika seseorang siap, kami membantu mereka menemukan bahwa cahaya yang selama ini mereka cari telah ada di dalam diri mereka sejak awal.</p>
                    </div>
                    <div class="mt-10 grid grid-cols-2 gap-4">
                        <div class="p-4 rounded-xl border" style="background:var(--accent-soft);border-color:var(--accent-border)"><i data-lucide="brain" class="w-5 h-5 mb-2" style="color:var(--accent)"></i><h4 class="text-sm font-semibold mb-0.5" style="color:var(--text-primary)" data-i18n="about_neuro_title">Neurosains</h4><p class="text-xs" style="color:var(--text-muted)" data-i18n="about_neuro_desc">Memahami ritme alami pembaruan otak</p></div>
                        <div class="p-4 rounded-xl border" style="background:var(--accent-soft);border-color:var(--accent-border)"><i data-lucide="heart" class="w-5 h-5 mb-2" style="color:var(--accent)"></i><h4 class="text-sm font-semibold mb-0.5" style="color:var(--text-primary)" data-i18n="about_psych_title">Psikologi</h4><p class="text-xs" style="color:var(--text-muted)" data-i18n="about_psych_desc">Pendekatan penuh kasih untuk penyembuhan batin</p></div>
                        <div class="p-4 rounded-xl border" style="background:var(--accent-soft);border-color:var(--accent-border)"><i data-lucide="lamp" class="w-5 h-5 mb-2" style="color:var(--accent)"></i><h4 class="text-sm font-semibold mb-0.5" style="color:var(--text-primary)" data-i18n="about_philo_title">Filsafat</h4><p class="text-xs" style="color:var(--text-muted)" data-i18n="about_philo_desc">Pertanyaan zaman yang membuka pintu baru</p></div>
                        <div class="p-4 rounded-xl border" style="background:var(--accent-soft);border-color:var(--accent-border)"><i data-lucide="sun" class="w-5 h-5 mb-2" style="color:var(--accent)"></i><h4 class="text-sm font-semibold mb-0.5" style="color:var(--text-primary)" data-i18n="about_wisdom_title">Kebijaksanaan Kuno</h4><p class="text-xs" style="color:var(--text-muted)" data-i18n="about_wisdom_desc">Praktik yang membimbing jiwa selama ribuan tahun</p></div>
                    </div>
                </div>
                <div class="relative">
                    <div class="relative rounded-2xl overflow-hidden border shadow-2xl gentle-glow" style="border-color:var(--border-main);box-shadow:var(--shadow-lg)">
                        <img src="https://picsum.photos/seed/forest-meditation-green/700/900.jpg" alt="Kontemplasi di alam" class="w-full h-[500px] lg:h-[650px] object-cover">
                        <div class="absolute inset-0 th-img-gradient"></div>
                        <div class="absolute bottom-8 left-8 right-8" style="background:var(--quote-bg);border-radius:12px;padding:16px 20px">
                            <p class="font-serif italic text-lg leading-relaxed" style="color:var(--text-primary)" data-i18n="about_quote">"Luka adalah tempat cahaya memasuki dirimu."</p>
                            <p class="text-xs mt-2" style="color:var(--text-muted)">— Rumi</p>
                        </div>
                    </div>
                    <div class="absolute -top-4 -right-4 w-24 h-24 rounded-full breathe" style="background:var(--accent-soft);border:1px solid var(--accent-border)"></div>
                    <div class="absolute -bottom-4 -left-4 w-16 h-16 rounded-full breathe-delay" style="background:var(--accent-soft);border:1px solid var(--accent-border)"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== PRODUCTS ===== -->
    <section id="products" class="relative py-24 md:py-32" style="background-color:var(--bg-elevated)">
        <div class="absolute inset-0 nature-pattern opacity-50"></div>
        <div class="relative max-w-7xl mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="products_tag">Produk</p>
                <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight mb-6" style="color:var(--text-primary)"><span data-i18n="products_title_1">Tiga cara pulang</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="products_title_2">ke dirimu sendiri</span></h2>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
                {products.map((product) => <ProductCard product={product} />)}
            </div>
            <div class="text-center mt-8">
                <a href="/products/" class="group text-sm inline-flex items-center gap-2" style="color:var(--text-muted)"><span data-i18n="products_all">Lihat semua produk</span><i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i></a>
            </div>
        </div>
    </section>

    <!-- ===== UPCOMING EVENT ===== -->
    <section id="event" class="relative py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="event_tag">Event Mendatang</p>
                <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight" style="color:var(--text-primary)"><span data-i18n="event_title_1">Langkah berikutnya</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="event_title_2">menunggumu</span></h2>
            </div>
            {nextEvent && <EventFeature event={nextEvent} linkToDetail />}
            <div class="text-center mt-8">
                <a href="/events/" class="group text-sm inline-flex items-center gap-2" style="color:var(--text-muted)"><span data-i18n="event_all">Lihat semua event</span><i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i></a>
            </div>
        </div>
    </section>

    <Testimonials />

    <!-- ===== STATS ===== -->
    <section class="relative py-16 border-y" style="border-color:var(--border-main)">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                <div><p class="font-serif text-3xl md:text-4xl font-semibold mb-2" style="color:var(--accent)">500+</p><p class="text-sm" style="color:var(--text-muted)" data-i18n="stat_1">Jiwa yang dijamah lembut</p></div>
                <div><p class="font-serif text-3xl md:text-4xl font-semibold mb-2" style="color:var(--accent)">7</p><p class="text-sm" style="color:var(--text-muted)" data-i18n="stat_2">Batch telah berjalan</p></div>
                <div><p class="font-serif text-3xl md:text-4xl font-semibold mb-2" style="color:var(--accent)">48</p><p class="text-sm" style="color:var(--text-muted)" data-i18n="stat_3">Guide tersertifikasi</p></div>
                <div><p class="font-serif text-3xl md:text-4xl font-semibold mb-2" style="color:var(--accent)">∞</p><p class="text-sm" style="color:var(--text-muted)" data-i18n="stat_4">Transformasi sunyi</p></div>
            </div>
        </div>
    </section>

    <!-- ===== BLOG ===== -->
    <section id="blog" class="relative py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
                <div>
                    <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="blog_tag">Tulisan</p>
                    <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight" style="color:var(--text-primary)"><span data-i18n="blog_title_1">Pikiran untuk</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="blog_title_2">jam-jam sunyi</span></h2>
                </div>
                <a href="/blog/" class="group text-sm flex items-center gap-2" style="color:var(--text-muted)"><span data-i18n="blog_all">Baca semua tulisan</span><i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i></a>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
                {posts.map((post) => <BlogCard post={post} />)}
            </div>
        </div>
    </section>

    <!-- ===== GIFT ===== -->
    <section id="gift" class="relative py-24 md:py-32" style="background-color:var(--bg-elevated)">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
                <div>
                    <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="gift_tag">Gift</p>
                    <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight" style="color:var(--text-primary)"><span data-i18n="gift_title_1">Sesuatu untuk</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="gift_title_2">kamu bawa pulang</span></h2>
                </div>
                <a href="/gift/" class="group text-sm flex items-center gap-2" style="color:var(--text-muted)"><span data-i18n="gift_all">Lihat semua gift</span><i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i></a>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
                {gifts.map((gift) => <GiftCard gift={gift} />)}
            </div>
        </div>
    </section>

    <!-- ===== CONTACT & SOCIAL ===== -->
    <section id="contact" class="relative py-24 md:py-32" style="background-color:var(--bg-elevated)">
        <div class="max-w-7xl mx-auto px-6">
            <div class="relative rounded-2xl overflow-hidden border p-10 md:p-16 text-center" style="border-color:var(--border-main);background:var(--bg-card)">
                <div class="absolute top-10 left-10 w-32 h-32 rounded-full breathe" style="background:var(--accent-soft);border:1px solid var(--accent-border)"></div>
                <div class="absolute bottom-10 right-10 w-24 h-24 rounded-full breathe-delay" style="background:var(--accent-soft);border:1px solid var(--accent-border)"></div>
                <div class="relative z-10">
                    <p class="text-xs font-bold tracking-[0.3em] uppercase mb-4" style="color:var(--accent)" data-i18n="social_tag">Tetap terhubung</p>
                    <h2 class="font-serif text-3xl md:text-5xl font-semibold leading-tight tracking-tight mb-6" style="color:var(--text-primary)"><span data-i18n="social_title_1">Obrolan berlanjut</span><br><span class="italic" style="color:var(--text-muted)" data-i18n="social_title_2">dengan lembut</span></h2>
                    <p class="leading-relaxed max-w-2xl mx-auto mb-10" style="color:var(--text-secondary)" data-i18n="social_desc">Kami berbagi pikiran yang sunyi, pengingat harian untuk bernapas, dan ruang untuk percakapan jujur. Tanpa hiruk-pikuk. Tanpa algoritma. Hanya komunitas yang belajar menjadi manusia bersama.</p>

                    <div class="mb-12 p-6 rounded-2xl border max-w-lg mx-auto" style="border-color:var(--accent-border);background:var(--accent-soft)">
                        <p class="text-sm mb-2" style="color:var(--text-muted)" data-i18n="contact_ready">Siap bergabung di Batch 8?</p>
                        <p class="font-serif text-xl font-semibold mb-3" style="color:var(--text-primary)" data-i18n="contact_person">Pelayan Breaktime</p>
                        <a href="https://wa.me/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 th-btn-primary px-6 py-3 rounded-full text-sm font-medium">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                            <span data-i18n="contact_wa">Hubungi via WhatsApp</span>
                        </a>
                    </div>

                    <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
                        <a href="https://instagram.com/breaktime.id" target="_blank" rel="noopener" class="group flex items-center gap-3 px-5 py-2.5 rounded-full border" style="border-color:var(--border-main);background:var(--bg-base)">
                            <svg class="w-5 h-5" style="color:var(--text-muted)" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                            <span class="text-sm" style="color:var(--text-secondary)">@breaktime.id</span>
                        </a>
                        <a href="https://tiktok.com/@breaktime.id" target="_blank" rel="noopener" class="group flex items-center gap-3 px-5 py-2.5 rounded-full border" style="border-color:var(--border-main);background:var(--bg-base)">
                            <svg class="w-5 h-5" style="color:var(--text-muted)" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43 6.34 6.34 0 001.87-4.51V8.73a8.19 8.19 0 004.71 1.49v-3.4a4.85 4.85 0 01-1-.13z"/></svg>
                            <span class="text-sm" style="color:var(--text-secondary)">TikTok</span>
                        </a>
                        <a href="https://youtube.com/@breaktime.id" target="_blank" rel="noopener" class="group flex items-center gap-3 px-5 py-2.5 rounded-full border" style="border-color:var(--border-main);background:var(--bg-base)">
                            <svg class="w-5 h-5" style="color:var(--text-muted)" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                            <span class="text-sm" style="color:var(--text-secondary)">YouTube</span>
                        </a>
                    </div>

                    <Newsletter />
                </div>
            </div>
        </div>
    </section>

</Base>
