---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'breaktime.id — ruang lembut untuk menemukan jalan pulang, dari malam tergelap menuju cahaya yang sunyi.',
} = Astro.props;
---
<html lang="id" data-theme="light" data-lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
</head>
<body class="antialiased overflow-x-hidden">

    <!-- Navigation -->
    <nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-500">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-2 group">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center group-hover:shadow-lg group-hover:shadow-green-500/30 transition-all duration-300"><i data-lucide="pause" class="w-4 h-4 text-white"></i></div>
                <span class="text-lg font-serif font-semibold tracking-tight" style="color:var(--text-primary)">breaktime<span style="color:var(--accent)">.id</span></span>
            </a>
            <div class="hidden md:flex items-center gap-6">
                <a href="/#about" class="text-sm hover:opacity-80 transition-opacity" style="color:var(--text-muted)" data-i18n="nav_about">Tentang</a>
                <a href="/#products" class="text-sm hover:opacity-80 transition-opacity" style="color:var(--text-muted)" data-i18n="nav_products">Produk</a>
                <a href="/#gift" class="text-sm hover:opacity-80 transition-opacity" style="color:var(--text-muted)" data-i18n="nav_gift">Gift</a>
                <a href="/#testimonials" class="text-sm hover:opacity-80 transition-opacity" style="color:var(--text-muted)" data-i18n="nav_stories">Cerita</a>
                <a href="/#blog" class="text-sm hover:opacity-80 transition-opacity" style="color:var(--text-muted)" data-i18n="nav_writings">Tulisan</a>
                <a href="/events/" class="th-btn-primary px-5 py-2.5 rounded-full text-sm font-medium" data-i18n="nav_cta">Daftar Batch 8</a>
            </div>
            <div class="flex md:hidden items-center gap-3">
                <button id="menuBtn" style="color:var(--text-muted)"><i data-lucide="menu" class="w-6 h-6"></i></button>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="mobile-menu fixed inset-y-0 right-0 w-72 z-50 p-8 flex flex-col gap-6 border-l" style="background-color:var(--bg-surface);border-color:var(--border-main)">
        <button id="closeMenu" style="color:var(--text-muted)" class="self-end"><i data-lucide="x" class="w-6 h-6"></i></button>
        <a href="/#about" class="text-lg mobile-link" style="color:var(--text-secondary)" data-i18n="nav_about">Tentang</a>
        <a href="/#products" class="text-lg mobile-link" style="color:var(--text-secondary)" data-i18n="nav_products">Produk</a>
        <a href="/#gift" class="text-lg mobile-link" style="color:var(--text-secondary)" data-i18n="nav_gift">Gift</a>
        <a href="/#testimonials" class="text-lg mobile-link" style="color:var(--text-secondary)" data-i18n="nav_stories">Cerita</a>
        <a href="/#blog" class="text-lg mobile-link" style="color:var(--text-secondary)" data-i18n="nav_writings">Tulisan</a>
        <a href="/events/" class="mt-4 th-btn-primary px-5 py-3 rounded-full text-center font-medium mobile-link" data-i18n="nav_cta">Daftar Batch 8</a>
    </div>
    <div id="menuOverlay" class="fixed inset-0 z-40 hidden" style="background-color:var(--overlay)"></div>

    <slot />

    <!-- ===== FOOTER ===== -->
    <footer class="border-t py-16" style="border-color:var(--border-main)">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-4 gap-12 mb-12">
                <div class="md:col-span-2">
                    <a href="/" class="flex items-center gap-2 mb-4">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center"><i data-lucide="pause" class="w-4 h-4 text-white"></i></div>
                        <span class="text-lg font-serif font-semibold tracking-tight" style="color:var(--text-primary)">breaktime<span style="color:var(--accent)">.id</span></span>
                    </a>
                    <p class="text-sm leading-relaxed max-w-sm" style="color:var(--text-muted)" data-i18n="footer_desc">Kerangka lembut untuk membantumu berhenti sejenak, bernapas, dan menemukan jalan pulang. Berakar pada kasih, dibimbing oleh kebijaksanaan, dijamah oleh komunitas.</p>
                </div>
                <div>
                    <h4 class="text-xs font-bold tracking-widest uppercase mb-4" style="color:var(--text-secondary)" data-i18n="footer_explore">Jelajahi</h4>
                    <ul class="space-y-3">
                        <li><a href="/#about" class="text-sm hover:opacity-80" style="color:var(--text-muted)" data-i18n="nav_about">Tentang</a></li>
                        <li><a href="/#products" class="text-sm hover:opacity-80" style="color:var(--text-muted)" data-i18n="nav_products">Produk</a></li>
                        <li><a href="/#gift" class="text-sm hover:opacity-80" style="color:var(--text-muted)" data-i18n="nav_gift">Gift</a></li>
                        <li><a href="/#testimonials" class="text-sm hover:opacity-80" style="color:var(--text-muted)" data-i18n="nav_stories">Cerita</a></li>
                        <li><a href="/#blog" class="text-sm hover:opacity-80" style="color:var(--text-muted)" data-i18n="nav_writings">Tulisan</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xs font-bold tracking-widest uppercase mb-4" style="color:var(--text-secondary)" data-i18n="footer_connect">Terhubung</h4>
                    <ul class="space-y-3">
                        <li><a href="https://instagram.com/breaktime.magic" target="_blank" rel="noopener" class="text-sm hover:opacity-80" style="color:var(--text-muted)">Instagram</a></li>
                        <li><a href="https://wa.me/6282338036703" target="_blank" rel="noopener" class="text-sm hover:opacity-80" style="color:var(--text-muted)">WhatsApp</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-color:var(--border-main)">
                <p class="text-xs" style="color:var(--text-faint)">© {new Date().getFullYear()} breaktime.id. All rights reserved.</p>
                <p class="text-xs italic font-serif" style="color:var(--text-faint)" data-i18n="footer_closing">Tarik napas. Kamu sudah cukup. 🌿</p>
            </div>
            <div class="hidden items-center justify-center gap-3 mt-8">
                <button id="langToggle" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase border transition-all duration-300" style="border-color:var(--border-main);color:var(--text-muted)"><i data-lucide="globe" class="w-3.5 h-3.5"></i><span id="langLabel">EN</span></button>
                <button id="themeToggle" class="flex items-center justify-center w-9 h-9 rounded-full border transition-all duration-300" style="border-color:var(--border-main);color:var(--text-muted)"><i data-lucide="moon" class="w-4 h-4" id="themeIcon"></i></button>
            </div>
        </div>
    </footer>

    <script>
        import { T } from '../lib/site';

        let currentLang: 'id' | 'en' = (localStorage.getItem('bt-lang') as 'id' | 'en') || 'id';
        function applyTranslations() {
            const l = T[currentLang];
            document.querySelectorAll('[data-i18n]').forEach((e) => {
                const k = e.getAttribute('data-i18n') as keyof typeof l;
                if (l[k] !== undefined) e.textContent = l[k];
            });
            document.querySelectorAll('[data-i18n-placeholder]').forEach((e) => {
                const k = e.getAttribute('data-i18n-placeholder') as keyof typeof l;
                if (l[k] !== undefined) (e as HTMLInputElement).placeholder = l[k];
            });
            document.documentElement.lang = currentLang;
            const nl = currentLang === 'id' ? 'EN' : 'ID';
            const label = document.getElementById('langLabel');
            if (label) label.textContent = nl;
        }
        function toggleLang() {
            currentLang = currentLang === 'id' ? 'en' : 'id';
            localStorage.setItem('bt-lang', currentLang);
            applyTranslations();
        }

        let currentTheme: 'light' | 'dark' = (localStorage.getItem('bt-theme') as 'light' | 'dark') || 'light';
        function applyTheme(t: 'light' | 'dark') {
            currentTheme = t;
            document.documentElement.setAttribute('data-theme', t);
            const n = t === 'dark' ? 'sun' : 'moon';
            document.getElementById('themeIcon')?.setAttribute('data-lucide', n);
            // @ts-ignore -- lucide is loaded globally via CDN script
            window.lucide?.createIcons();
        }
        function toggleTheme() {
            const next = currentTheme === 'light' ? 'dark' : 'light';
            localStorage.setItem('bt-theme', next);
            applyTheme(next);
        }

        document.addEventListener('DOMContentLoaded', () => {
            // @ts-ignore
            window.lucide?.createIcons();
            document.getElementById('langToggle')?.addEventListener('click', toggleLang);
            document.getElementById('themeToggle')?.addEventListener('click', toggleTheme);
            applyTranslations();
            applyTheme(currentTheme);

            const nb = document.getElementById('navbar');
            window.addEventListener('scroll', () => {
                window.scrollY > 50 ? nb?.classList.add('navbar-scrolled') : nb?.classList.remove('navbar-scrolled');
            });

            const mm = document.getElementById('mobileMenu');
            const mo = document.getElementById('menuOverlay');
            function cm() {
                mm?.classList.remove('open');
                mo?.classList.add('hidden');
                document.body.style.overflow = '';
            }
            document.getElementById('menuBtn')?.addEventListener('click', () => {
                mm?.classList.add('open');
                mo?.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            });
            document.getElementById('closeMenu')?.addEventListener('click', cm);
            mo?.addEventListener('click', cm);
            document.querySelectorAll('.mobile-link').forEach((l) => l.addEventListener('click', cm));

            const obs = new IntersectionObserver(
                (entries) => {
                    entries.forEach((en) => {
                        if (en.isIntersecting) {
                            (en.target as HTMLElement).style.opacity = '1';
                            (en.target as HTMLElement).style.transform = 'translateY(0)';
                        }
                    });
                },
                { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
            );
            document.querySelectorAll('section').forEach((s, i) => {
                if (i === 0) return;
                (s as HTMLElement).style.opacity = '0';
                (s as HTMLElement).style.transform = 'translateY(20px)';
                (s as HTMLElement).style.transition = 'opacity 0.8s ease, transform 0.8s ease';
                obs.observe(s);
            });
        });
    </script>
</body>
</html>
